# =============================================================================
# Office Repo — Frontend (Vite) Environment Template
# =============================================================================
# Copy to `frontend/.env` and fill in real values:
#   cp frontend/.env.example frontend/.env
# `frontend/.env` is git-ignored. Only VITE_-prefixed vars are exposed to
# the browser bundle — never put secrets here.
# =============================================================================

# Base URL for API requests. Leave EMPTY to use same-origin relative `/api`
# requests (the default; works with the Vite dev proxy and same-domain prod).
# Set an absolute URL only when the API is hosted on a different origin.
# Example: https://api.officerepo.com
VITE_API_URL=

# Cloudflare Turnstile site key (public). Pairs with the backend
# TURNSTILE_SECRET_KEY. Leave blank to disable the widget on the enquiry form.
VITE_TURNSTILE_SITE_KEY=

# Base domain for tenant subdomains (subdomain-type client portals).
# In production set this to your root domain, e.g.: officerepo.com
# → portal URL becomes https://{subdomain}.officerepo.com
# Leave EMPTY in development — the app falls back to a path-based URL:
# → {window.location.origin}/portal/{subdomain}  (fully functional in dev)
VITE_BASE_DOMAIN=
