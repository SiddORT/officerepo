# =============================================================================
# Office Repo — Environment Template
# =============================================================================
# Copy this file to `.env` and fill in real values for your environment.
#   cp .env.example .env
# `.env` is git-ignored — NEVER commit real secrets. This template uses safe
# placeholder values only.
#
# This file documents BACKEND configuration. Frontend (VITE_*) variables live
# in `frontend-web/.env` (see `frontend-web/.env.example`).
# =============================================================================

# -----------------------------------------------------------------------------
# Core / runtime
# -----------------------------------------------------------------------------
# development | production  — controls CORS strictness, secret guards, etc.
ENVIRONMENT=development

# PostgreSQL connection string. On Replit this is auto-set; on your own infra
# provide it explicitly. `postgres://` and `postgresql://` are auto-normalised.
DATABASE_URL=postgresql://user:password@localhost:5432/office_repo_platform

# Optional explicit platform DB URL. Falls back to DATABASE_URL when unset.
# PLATFORM_DB_URL=

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
# Signing keys — generate strong random values (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_SECRET=change-me-to-a-different-long-random-string
# Legacy alias used as a fallback for JWT_SECRET if the above is unset.
# SESSION_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Secret rotation (graceful rollover — see settings.py for the procedure)
# -----------------------------------------------------------------------------
# PREVIOUS_JWT_SECRET=
# PREVIOUS_REFRESH_SECRET=
# ISO-8601 UTC timestamp when rotation happened, e.g. 2026-05-07T12:00:00Z
# PREVIOUS_SECRET_ISSUED_AT=
PREVIOUS_SECRET_GRACE_HOURS=168
PREVIOUS_SECRET_CHECK_INTERVAL_HOURS=1
# Minimum minutes between API-driven rotations (0 disables the cooldown).
ROTATE_SECRETS_COOLDOWN_MINUTES=60
# Optional webhook to POST a JSON alert to when stale PREVIOUS_* secrets persist.
# SECRET_ROTATION_ALERT_URL=
# Optional alert metadata merged into the webhook payload.
# SECRET_ROTATION_ALERT_SEVERITY=warning
# SECRET_ROTATION_ALERT_ENV_TAG=production

# -----------------------------------------------------------------------------
# Multi-tenancy & CORS
# -----------------------------------------------------------------------------
# header | subdomain | jwt
TENANT_RESOLVER_STRATEGY=header

# Comma-separated explicit CORS origins (required in production).
# officerepo.com and all *.officerepo.com subdomains are ALWAYS allowed in
# non-development environments in addition to this list.
# Example: https://app.officerepo.com,https://admin.officerepo.com
ALLOWED_ORIGINS=

# Number of trusted reverse-proxy / CDN hops in front of the app (for real
# client-IP resolution from X-Forwarded-For). Replit uses 1.
TRUSTED_PROXY_HOPS=1

# -----------------------------------------------------------------------------
# Public enquiries — PII encryption & privacy/compliance
# -----------------------------------------------------------------------------
# Comma-separated urlsafe-base64 Fernet keys (1st encrypts; all decrypt — enables
# key rotation). When blank a key is derived from SESSION_SECRET/JWT_SECRET.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENQUIRY_ENCRYPTION_KEYS=
PRIVACY_POLICY_VERSION=1.0
ENQUIRY_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# Live exchange-rate provider (Currency Management → "Run Sync Now")
# -----------------------------------------------------------------------------
# Built-in provider targets exchangerate-api.com (v6). Set the API key to enable
# live sync (registered as the "Forex API" source); leave blank to keep live sync
# disabled (Manual rate entry still works). Get a free key at exchangerate-api.com.
# EXCHANGE_RATE_API_KEY=
# Override the provider base URL (default: https://v6.exchangerate-api.com/v6).
# EXCHANGE_RATE_API_URL=
# Per-request HTTP timeout in seconds (default: 10).
# EXCHANGE_RATE_API_TIMEOUT=10

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (optional bot protection for the public enquiry form)
# -----------------------------------------------------------------------------
# Backend secret key. The matching site key goes in frontend-web/.env as
# VITE_TURNSTILE_SITE_KEY. Leave blank to disable enforcement.
# TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Notifications (all optional — each channel stays disabled until its vars exist)
# -----------------------------------------------------------------------------
# Email (SMTP)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true

# SMS + WhatsApp (Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
# TWILIO_WHATSAPP_FROM=

# Push (Firebase Cloud Messaging legacy server key)
# FCM_SERVER_KEY=

# -----------------------------------------------------------------------------
# Process management (used by ecosystem.config.cjs / PM2)
# -----------------------------------------------------------------------------
# Port the FastAPI backend (uvicorn) binds to when managed by PM2.
BACKEND_PORT=8000
# Port the frontend preview server binds to when managed by PM2.
FRONTEND_PORT=5000
